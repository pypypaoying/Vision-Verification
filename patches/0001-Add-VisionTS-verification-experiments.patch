@@ -0,0 +1,94 @@
+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+LTSF_DIR="$(cd "${SCRIPT_DIR}/../.." && pwd)"
+cd "${LTSF_DIR}"
+
+: "${DATA_NAME:?DATA_NAME is required, e.g. ETTm1}"
+: "${DATA:?DATA is required, e.g. ETTm1 or custom}"
+: "${ROOT_PATH:?ROOT_PATH is required, relative to long_term_tsf is OK}"
+: "${DATA_PATH:?DATA_PATH is required, e.g. ETTm1.csv}"
+: "${CONTEXT_LEN:?CONTEXT_LEN is required}"
+: "${PERIODICITY:?PERIODICITY is required}"
+
+export PYTHONPATH="${LTSF_DIR}/..:${PYTHONPATH:-}"
+
+FEATURES="${FEATURES:-M}"
+TARGET="${TARGET:-OT}"
+FREQ="${FREQ:-h}"
+LABEL_LEN="${LABEL_LEN:-48}"
+PRED_LENS="${PRED_LENS:-96 192 336 720}"
+BATCH_SIZE="${BATCH_SIZE:-32}"
+NUM_WORKERS="${NUM_WORKERS:-10}"
+CKPT_DIR="${CKPT_DIR:-../ckpt/}"
+VM_ARCH="${VM_ARCH:-mae_base}"
+ALIGN_CONST="${ALIGN_CONST:-0.4}"
+NORM_CONST="${NORM_CONST:-0.4}"
+INTERPOLATION="${INTERPOLATION:-bilinear}"
+ABLATION_SEED="${ABLATION_SEED:-0}"
+ABLATIONS="${ABLATIONS:-none stats_only time_reverse time_permute row_shuffle col_shuffle image_patch_shuffle}"
+RESULT_ROOT="${RESULT_ROOT:-save/vision_verification}"
+RUN_SEASONAL_NAIVE="${RUN_SEASONAL_NAIVE:-1}"
+RUN_VISIONTS="${RUN_VISIONTS:-1}"
+SKIP_DONE="${SKIP_DONE:-1}"
+
+run_case() {
+    local model="$1"
+    local variant="$2"
+    local pred_len="$3"
+    shift 3
+
+    local save_dir="${RESULT_ROOT}/${DATA_NAME}/pl_${pred_len}/${model}/${variant}"
+    local metrics_path="${save_dir}/results/_/metrics.npy"
+
+    if [[ "${SKIP_DONE}" == "1" && -f "${metrics_path}" ]]; then
+        echo "[skip] ${DATA_NAME} pred_len=${pred_len} model=${model} variant=${variant}"
+        return
+    fi
+
+    mkdir -p "${save_dir}"
+    echo "[run] ${DATA_NAME} pred_len=${pred_len} model=${model} variant=${variant}"
+
+    python -u run.py \
+        --task_name long_term_forecast \
+        --is_training 1 \
+        --model "${model}" \
+        --root_path "${ROOT_PATH}" \
+        --data_path "${DATA_PATH}" \
+        --save_dir "${save_dir}" \
+        --model_id "${model}_${variant}_${DATA_NAME}_${pred_len}" \
+        --data "${DATA}" \
+        --features "${FEATURES}" \
+        --target "${TARGET}" \
+        --freq "${FREQ}" \
+        --train_epochs 0 \
+        --batch_size "${BATCH_SIZE}" \
+        --num_workers "${NUM_WORKERS}" \
+        --seq_len "${CONTEXT_LEN}" \
+        --label_len "${LABEL_LEN}" \
+        --periodicity "${PERIODICITY}" \
+        --pred_len "${pred_len}" \
+        --vm_arch "${VM_ARCH}" \
+        --vm_ckpt "${CKPT_DIR}" \
+        --norm_const "${NORM_CONST}" \
+        --align_const "${ALIGN_CONST}" \
+        --interpolation "${INTERPOLATION}" \
+        "$@" 2>&1 | tee "${save_dir}/run.log"
+}
+
+for pred_len in ${PRED_LENS}; do
+    if [[ "${RUN_SEASONAL_NAIVE}" == "1" ]]; then
+        run_case "SeasonalNaive" "period_${PERIODICITY}" "${pred_len}" \
+            --ablation none \
+            --ablation_seed "${ABLATION_SEED}"
+    fi
+
+    if [[ "${RUN_VISIONTS}" == "1" ]]; then
+        for ablation in ${ABLATIONS}; do
+            run_case "VisionTS" "${ablation}" "${pred_len}" \
+                --ablation "${ablation}" \
+                --ablation_seed "${ABLATION_SEED}"
+        done
+    fi
+done
diff --git a/long_term_tsf/scripts/vision_verification/summarize_verification.py b/long_term_tsf/scripts/vision_verification/summarize_verification.py
new file mode 100755
index 0000000..77cb37a
--- /dev/null
+++ b/long_term_tsf/scripts/vision_verification/summarize_verification.py
@@ -0,0 +1,86 @@
+#!/usr/bin/env python
+import argparse
+import csv
+from pathlib import Path
+
+import numpy as np
+
+
+METRIC_NAMES = [
+    "mae",
+    "mse",
+    "rmse",
+    "mape",
+    "mspe",
+    "best_valid_loss",
+    "best_valid_epoch",
+]
+
+
+def parse_metric_path(root, path):
+    rel_parts = path.relative_to(root).parts
+    if len(rel_parts) < 7:
+        return None
+    if rel_parts[-3:] != ("results", "_", "metrics.npy"):
+        return None
+
+    data_name = rel_parts[-7]
+    pred_len = rel_parts[-6].replace("pl_", "")
+    model = rel_parts[-5]
+    variant = rel_parts[-4]
+    return data_name, pred_len, model, variant
+
+
+def main():
+    parser = argparse.ArgumentParser(description="Summarize VisionTS verification metrics.")
+    parser.add_argument("--root", type=Path, default=Path("save/vision_verification"))
+    parser.add_argument("--out", type=Path, default=None)
+    args = parser.parse_args()
+
+    root = args.root
+    metric_paths = sorted(root.glob("**/results/_/metrics.npy"))
+    rows = []
+
+    for path in metric_paths:
+        parsed = parse_metric_path(root, path)
+        if parsed is None:
+            continue
+        data_name, pred_len, model, variant = parsed
+        metrics = np.load(path)
+        row = {
+            "data": data_name,
+            "pred_len": int(pred_len),
+            "model": model,
+            "variant": variant,
+            "metrics_path": str(path),
+        }
+        for name, value in zip(METRIC_NAMES, metrics):
+            row[name] = float(value)
+        rows.append(row)
+
+    rows.sort(key=lambda x: (x["data"], x["pred_len"], x["model"], x["variant"]))
+
+    if not rows:
+        raise SystemExit(f"No metrics.npy files found under {root}")
+
+    fieldnames = ["data", "pred_len", "model", "variant"] + METRIC_NAMES + ["metrics_path"]
+    out_path = args.out or root / "summary.csv"
+    out_path.parent.mkdir(parents=True, exist_ok=True)
+
+    with out_path.open("w", newline="") as f:
+        writer = csv.DictWriter(f, fieldnames=fieldnames)
+        writer.writeheader()
+        writer.writerows(rows)
+
+    print(f"Wrote {len(rows)} rows to {out_path}")
+    print("Top rows by MSE:")
+    for row in sorted(rows, key=lambda x: x["mse"])[:20]:
+        print(
+            f"{row['data']:>8} pl={row['pred_len']:<3} "
+            f"{row['model']:<13} {row['variant']:<20} "
+            f"mse={row['mse']:.6g} mae={row['mae']:.6g}"
+        )
+
+
+if __name__ == "__main__":
+    main()
