+        ETTm1)
+            export DATA_NAME="ETTm1"
+            export DATA="ETTm1"
+            export ROOT_PATH="./dataset/ETT-small/"
+            export DATA_PATH="ETTm1.csv"
+            export CONTEXT_LEN="2304"
+            export PERIODICITY="96"
+            export FREQ="t"
+            ;;
+        ETTm2)
+            export DATA_NAME="ETTm2"
+            export DATA="ETTm2"
+            export ROOT_PATH="./dataset/ETT-small/"
+            export DATA_PATH="ETTm2.csv"
+            export CONTEXT_LEN="4032"
+            export PERIODICITY="96"
+            export FREQ="t"
+            ;;
+        ETTh1)
+            export DATA_NAME="ETTh1"
+            export DATA="ETTh1"
+            export ROOT_PATH="./dataset/ETT-small/"
+            export DATA_PATH="ETTh1.csv"
+            export CONTEXT_LEN="2880"
+            export PERIODICITY="24"
+            export FREQ="h"
+            ;;
+        ETTh2)
+            export DATA_NAME="ETTh2"
+            export DATA="ETTh2"
+            export ROOT_PATH="./dataset/ETT-small/"
+            export DATA_PATH="ETTh2.csv"
+            export CONTEXT_LEN="1728"
+            export PERIODICITY="24"
+            export FREQ="h"
+            ;;
+        ECL)
+            export DATA_NAME="ECL"
+            export DATA="custom"
+            export ROOT_PATH="./dataset/electricity/"
+            export DATA_PATH="electricity.csv"
+            export CONTEXT_LEN="2880"
+            export PERIODICITY="24"
+            export FREQ="h"
+            ;;
+        Weather)
+            export DATA_NAME="Weather"
+            export DATA="custom"
+            export ROOT_PATH="./dataset/weather/"
+            export DATA_PATH="weather.csv"
+            export CONTEXT_LEN="4032"
